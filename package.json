{
  "name": "eternal-pose",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}\"",
    "check-types": "turbo run check-types",
    "check": "pnpm run lint && pnpm run format && pnpm run check-types",
    "commit": "git add . && git cz",
    "release": "pnpm changeset && pnpm changeset version && git add . && git commit -m 'chore: release' && git push --follow-tags"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "cz-git": "^1.12.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.7.4",
    "turbo": "^2.9.1",
    "typescript": "5.9.2"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": true
    }
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  }
}
